export type AbilitySlot = "Primary" | "Secondary" | "Ultimate"
export type AbilityAction = "Projectile" | "Shield" | "Dash" | "Burst" | "Heal" | "Shockwave"
export type ElementName = "Earth" | "Air" | "Fire" | "Water"
export type RewardId = "RunedBlade" | "TitanMail" | "ArcaneHourglass" | "HeroicAwakening"

export type AbilityDefinition = {
    Id: string,
    Name: string,
    Description: string,
    Slot: AbilitySlot,
    Action: AbilityAction,
    UnlockProgress: number,
    Cooldown: number,
    Range: number,
    BaseDamage: number,
    BurstRadius: number?,
    DashDistance: number?,
    Duration: number?,
    Heal: number?,
    Shield: number?,
    SlowDuration: number?,
    BurnDamage: number?,
    BurnTicks: number?,
    WalkSpeedBonus: number?,
}

export type ElementDefinition = {
    DisplayName: string,
    Summary: string,
    ThemeColor: Color3,
    AccentColor: Color3,
    Abilities: {
        Primary: AbilityDefinition,
        Secondary: AbilityDefinition,
        Ultimate: AbilityDefinition,
    },
}

export type RewardDefinition = {
    Id: RewardId,
    Name: string,
    Description: string,
    DamageBonus: number,
    HealthBonus: number,
    CooldownMultiplier: number,
