{
	"version": "2.0.0",
	"options": {
		"cwd": "${workspaceFolder}"
	},
	"tasks": [
		{
			"label": "Roblox: Do all tasks",
			"type": "shell",
			"command": "${env:LOCALAPPDATA}\\Microsoft\\WindowsApps\\pwsh.exe",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"scripts/do-all-tasks.ps1",
				"-McpRetryAttempts",
				"3"
			],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": false,
				"showReuseMessage": false
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [],
			"detail": "Single entrypoint: setup, connect, and iterative Roblox dev loop until Ctrl+C or DONE sentinel."
		}
	]
}
